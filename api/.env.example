# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shipmenthub_dev
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/shipmenthub_test

# Database connection retry on startup (helps when the API starts before the DB,
# e.g. inside containers). Optional — sensible defaults are used if omitted.
DB_CONNECT_RETRIES=10
DB_CONNECT_RETRY_DELAY_MS=3000

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS — allowed web origin
CLIENT_ORIGIN=http://localhost:3000
